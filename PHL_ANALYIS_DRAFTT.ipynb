   ]
  },
  {
   "cell_type": "code",
   "execution_count": 134,
   "id": "c9413869",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Outcome variable \"Binary indicator of PHL occurrence\"\n",
    "data[\"PHL_binary\"] = (data[\"total_loss\"] > 0).astype(int)\n",
    "\n",
    "# Continuous PHL rate\n",
    "data[\"PHL_rate\"] = data[\"total_loss\"] / data[\"gross_production\"]\n",
    "\n",
    "# Clean extreme and missing values\n",
    "data[\"PHL_rate\"] = (\n",
    "    data[\"PHL_rate\"]\n",
    "    .replace([np.inf, -np.inf], 0)\n",
    "    .fillna(0)\n",
    "    .clip(0, 1)\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 133,
   "id": "93f4debb",
   "metadata": {},
   "outputs": [],
   "source": [
    "##Treatment variables\n",
    "data[\"Storage_access\"] = data[\n",
    "    \"Q.2.37 What is the storage facility used during this agricultural season?\"\n",
    "].apply(lambda x: 0 if str(x).lower() in [\"none\", \"no\", \"nan\"] else 1)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 124,
   "id": "f895aae5",
   "metadata": {},
   "outputs": [],
   "source": [
    "formal_markets = [\"Market\", \"Cooperative\", \"Company\", \"Association\"]\n",
    "\n",
    "data[\"Market_access\"] = data[\n",
    "    \"Q.2.27 On which market this crop was sold?\"\n",
    "].apply(lambda x: 1 if str(x) in formal_markets else 0)"
   ]
  },
