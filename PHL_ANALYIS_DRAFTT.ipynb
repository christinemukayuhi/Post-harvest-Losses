   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import warnings\n",
    "warnings.filterwarnings(\"ignore\")\n",
    "file_path = r\"E:\\R_Thesis\\SAS_2024F.xlsx\"\n",
    "\n",
    "coordinates = pd.read_excel(file_path, sheet_name=\"Coordinates\")\n",
    "season_a = pd.read_excel(file_path, sheet_name=\"SeasonA\")\n",
    "season_b = pd.read_excel(file_path, sheet_name=\"SeasonB\")\n",
    "season_c = pd.read_excel(file_path, sheet_name=\"SeasonC\")\n",
    "\n",
    "print(season_a.shape, season_b.shape, season_c.shape)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 90,
   "id": "cc863c3b",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Combined data: (76863, 81)\n"
     ]
    }
   ],
   "source": [
    "season_all = pd.concat([season_a, season_b, season_c], ignore_index=True)\n",
    "print(\"Combined data:\", season_all.shape)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 91,
   "id": "6cea57e7",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Merged data: (76863, 84)\n",
      "Missing latitude: 0\n"
     ]
    }
   ],
   "source": [
    "data = season_all.merge(coordinates, on=\"District_Cl\", how=\"left\")\n",
    "\n",
    "print(\"Merged data:\", data.shape)\n",
    "print(\"Missing latitude:\", data[\"latitude\"].isna().sum())"
   ]
  },
